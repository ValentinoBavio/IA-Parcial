# =========================================================
# Unity .gitignore
# Colocar este archivo en la carpeta raíz del proyecto
# =========================================================

# Unity generated folders
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]ser[Ss]ettings/

# MemoryCaptures
[Mm]emoryCaptures/

# Asset Store Tools
[Aa]ssets/AssetStoreTools*

# Autogenerated VS / Rider / IDE files
.vs/
.vscode/
.idea/
*.csproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Rider
.idea/
*.DotSettings.user

# Visual Studio cache/options
*.VC.opendb
*.suo
*.user
*.userosscache
*.sln.docstates

# Unity cache server
[Ll]ibrary/[Aa]rtifactDB
[Ll]ibrary/[Bb]ee/
[Ll]ibrary/[Ss]criptAssemblies/
[Ll]ibrary/[Ss]haderCache/

# Crash reports
sysinfo.txt

# Builds
*.apk
*.aab
*.unitypackage

# OS files
.DS_Store
Thumbs.db
Desktop.ini

# Git merge backup files
*.orig
*.rej
*.bak

# Keep project settings, packages and assets tracked
![Aa]ssets/
![Pp]ackages/
![Pp]roject[Ss]ettings/
